---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About MogooStudio — an independent mobile game studio.">
  <section class="page-hero">
    <h1>About <span class="accent">Us</span></h1>
  </section>

  <section class="about-content">
    <div class="about-inner">
      <p class="lead">
        MogooStudio is a one-person indie game studio with one simple goal: build mobile games
        that feel good to play.
      </p>
      <p>
        Every project starts with the same question — what makes this satisfying to pick up and
        put down? We skip the complexity, the energy systems, the dark patterns. Just clean
        mechanics, polished to a shine.
      </p>
      <p>
        We work in public, ship small, and improve fast. If you've played one of our games and
        have thoughts, we'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="about-strip-wrap">
    <div class="about-strip">
      <div class="about-strip-item">
        <div class="num">2</div>
        <div class="label">Games Shipped</div>
      </div>
      <div class="about-strip-divider"></div>
      <div class="about-strip-item">
        <div class="num">1</div>
        <div class="label">Indie Studio</div>
      </div>
      <div class="about-strip-divider"></div>
      <div class="about-strip-item">
        <div class="num">∞</div>
        <div class="label">Fun Promised</div>
      </div>
    </div>
  </section>

  <section class="contact-wrap">
    <div class="contact-block">
      <h2>Get in touch</h2>
      <p>Questions, feedback, or just want to chat about games?</p>
      <a href="mailto:mogoostudio@outlook.com" class="email-btn">
        mogoostudio@outlook.com
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 80px 40px 64px;
    text-align: center;
    background: #f8f8f8;
  }

  .page-hero h1 {
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    color: #222;
  }

  .page-hero h1 .accent { color: #F2455C; }

  .page-hero p {
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    color: #666;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .about-content {
    padding: 64px 40px 56px;
    max-width: 760px;
    margin: 0 auto;
  }

  .lead {
    font-family: "Poppins", sans-serif;
    font-size: 19px;
    font-weight: 600;
    color: #333;
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .about-content p:not(.lead) {
    font-family: "Poppins", sans-serif;
    font-size: 14.5px;
    color: #555;
    line-height: 1.8;
    margin-bottom: 18px;
  }

  .about-strip-wrap {
    padding: 0 40px 80px;
    max-width: 900px;
    margin: 0 auto;
  }

  .about-strip {
    display: flex;
    border: 1px solid #eee;
    border-radius: 20px;
    overflow: hidden;
  }

  .about-strip-item {
    flex: 1;
    padding: 36px 32px;
    text-align: center;
  }

  .about-strip-item .num {
    font-size: 40px;
    font-weight: 800;
    color: #29C4D9;
    line-height: 1;
    margin-bottom: 8px;
  }

  .about-strip-item .label {
    font-family: "Poppins", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #888;
  }

  .about-strip-divider {
    width: 1px;
    background: #eee;
    margin: 20px 0;
  }

  .contact-wrap {
    background: #f8f8f8;
    padding: 40px 40px 80px;
  }

  .contact-block {
    background: #181818;
    border-radius: 24px;
    padding: 56px 40px;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-block h2 {
    font-size: 32px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 12px;
  }

  .contact-block p {
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    color: #aaa;
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .email-btn {
    display: inline-block;
    background: #F2455C;
    color: #fff;
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 32px;
    border-radius: 50px;
    transition: transform .2s, box-shadow .2s;
  }

  .email-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(242,69,92,.4);
  }

  @media (max-width: 640px) {
    .about-strip { flex-direction: column; }
    .about-strip-divider { width: auto; height: 1px; margin: 0 20px; }
    .page-hero, .about-content, .about-strip-wrap, .contact-wrap { padding-left: 24px; padding-right: 24px; }
  }
</style>
