---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('nav.support')} description="Support & FAQ for MogooStudio games.">
  <section class="page-hero">
    <h1>{t('support.h1a')} <span class="accent">{t('support.h1b')}</span></h1>
  </section>

  <section class="faq-section">
    <div class="faq-inner">
      <h2 class="sec-title">{t('support.faq.title')}</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            {t('support.faq.q1')}
            <svg class="faq-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-body">
            <p>{t('support.faq.a1').replace('mogoostudio@outlook.com', '')} <a href="mailto:mogoostudio@outlook.com">mogoostudio@outlook.com</a>{t('support.faq.a1').includes('mogoostudio@outlook.com') ? '' : ''}</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            {t('support.faq.q2')}
            <svg class="faq-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-body"><p>{t('support.faq.a2')}</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            {t('support.faq.q3')}
            <svg class="faq-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-body"><p>{t('support.faq.a3')}</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            {t('support.faq.q4')}
            <svg class="faq-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-body"><p>{t('support.faq.a4')}</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="contact-wrap">
    <div class="contact-block">
      <h2>{t('support.contact.h2')}</h2>
      <p>{t('support.contact.p')}</p>
      <a href="mailto:mogoostudio@outlook.com" class="email-btn">mogoostudio@outlook.com</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 80px 40px 64px;
    text-align: center;
    background: #f8f8f8;
  }

  .page-hero h1 {
    font-size: clamp(40px, 7vw, 68px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    color: #222;
  }

  .page-hero h1 .accent { color: #F2455C; }

  .page-hero p {
    font-family: "Nunito", sans-serif;
    font-size: 16px;
    color: #666;
    line-height: 1.6;
  }

  .faq-section {
    padding: 56px 40px 48px;
    border-bottom: 1px solid #eee;
  }

  .faq-inner {
    max-width: 880px;
    margin: 0 auto;
  }

  .faq-list { display: flex; flex-direction: column; }

  .faq-item {
    border-bottom: 1px solid #eee;
  }

  .faq-item:first-child { border-top: 1px solid #eee; }

  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: "Nunito", sans-serif;
    font-size: 16px;
    font-weight: 800;
    color: #222;
    text-align: left;
    transition: color .2s;
  }

  .faq-q:hover { color: #F2455C; }

  .faq-q[aria-expanded="true"] { color: #F2455C; }

  .faq-arrow {
    flex-shrink: 0;
    color: #aaa;
    transition: transform .3s ease, color .2s;
  }

  .faq-q[aria-expanded="true"] .faq-arrow {
    transform: rotate(180deg);
    color: #F2455C;
  }

  .faq-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height .35s ease, padding .35s ease;
  }

  .faq-item.open .faq-body {
    max-height: 200px;
    padding-bottom: 20px;
  }

  .faq-body p {
    font-family: "Nunito", sans-serif;
    font-size: 14px;
    color: #555;
    line-height: 1.7;
  }

  .faq-body p a { color: #F2455C; }
  .faq-body p a:hover { text-decoration: underline; }

  .contact-wrap {
    background: #f8f8f8;
    padding: 48px 40px 80px;
  }

  .contact-block {
    background: #181818;
    border-radius: 24px;
    padding: 56px 40px;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-block h2 {
    font-size: 28px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 12px;
  }

  .contact-block p {
    font-family: "Nunito", sans-serif;
    font-size: 15px;
    color: #aaa;
    margin-bottom: 28px;
  }

  .email-btn {
    display: inline-block;
    background: #F2455C;
    color: #fff;
    font-family: "Nunito", sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 32px;
    border-radius: 50px;
    transition: transform .2s, box-shadow .2s;
  }

  .email-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(242,69,92,.4);
  }

  @media (max-width: 640px) {
    .page-hero, .faq-section, .contact-wrap { padding-left: 24px; padding-right: 24px; }
  }
</style>

<script>
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const isOpen = item.classList.contains('open');

      document.querySelectorAll('.faq-item.open').forEach(el => {
        el.classList.remove('open');
        el.querySelector('.faq-q')?.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
