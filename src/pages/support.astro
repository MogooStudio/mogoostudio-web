---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Support" description="Support & FAQ for MogooStudio games.">
  <section class="page-hero">
    <h1>Support <span class="accent">&amp; Help</span></h1>
  </section>

  <section class="faq-section">
    <div class="faq-inner">
      <h2 class="sec-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>How do I contact support?</h3>
          <p>Email us at <a href="mailto:mogoostudio@outlook.com">mogoostudio@outlook.com</a>. We respond within 48 hours.</p>
        </div>
        <div class="faq-item">
          <h3>I found a bug. How do I report it?</h3>
          <p>Send an email describing what happened, which device you're on, and the iOS/Android version. Screenshots always help!</p>
        </div>
        <div class="faq-item">
          <h3>Are your games free to play?</h3>
          <p>Yes — all MogooStudio games are free to download with no ads and no in-app purchases. Just pure gameplay.</p>
        </div>
        <div class="faq-item">
          <h3>Will you add more games?</h3>
          <p>Absolutely. We're a small studio with big ambitions. Follow our progress on the home page.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="contact-wrap">
    <div class="contact-block">
      <h2>Still have a question?</h2>
      <p>We're always happy to help — reach out anytime.</p>
      <a href="mailto:mogoostudio@outlook.com" class="email-btn">mogoostudio@outlook.com</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 80px 40px 64px;
    text-align: center;
    background: #f8f8f8;
  }

  .page-hero h1 {
    font-size: clamp(40px, 7vw, 68px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    color: #222;
  }

  .page-hero h1 .accent { color: #F2455C; }

  .page-hero p {
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    color: #666;
    line-height: 1.6;
  }

  .faq-section {
    padding: 56px 40px 48px;
    border-bottom: 1px solid #eee;
  }

  .faq-inner {
    max-width: 880px;
    margin: 0 auto;
  }

  .faq-list { display: flex; flex-direction: column; }

  .faq-item {
    padding: 24px 0;
    border-bottom: 1px solid #eee;
  }

  .faq-item:first-child { border-top: 1px solid #eee; }

  .faq-item h3 {
    font-size: 16px;
    font-weight: 800;
    color: #222;
    margin-bottom: 8px;
  }

  .faq-item p {
    font-family: "Poppins", sans-serif;
    font-size: 14px;
    color: #555;
    line-height: 1.7;
  }

  .faq-item p a { color: #F2455C; }
  .faq-item p a:hover { text-decoration: underline; }

  .contact-wrap {
    background: #f8f8f8;
    padding: 48px 40px 80px;
  }

  .contact-block {
    background: #181818;
    border-radius: 24px;
    padding: 56px 40px;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-block h2 {
    font-size: 28px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 12px;
  }

  .contact-block p {
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    color: #aaa;
    margin-bottom: 28px;
  }

  .email-btn {
    display: inline-block;
    background: #F2455C;
    color: #fff;
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 32px;
    border-radius: 50px;
    transition: transform .2s, box-shadow .2s;
  }

  .email-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(242,69,92,.4);
  }

  @media (max-width: 640px) {
    .page-hero, .games-section, .faq-section, .contact-wrap { padding-left: 24px; padding-right: 24px; }
    .game-card { padding: 20px 20px 20px 28px; }
  }
</style>
