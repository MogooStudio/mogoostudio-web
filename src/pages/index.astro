---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameBlock from '../components/GameBlock.astro';
---

<BaseLayout title="MogooStudio | Small games. Big fun." description="MogooStudio — Independent mobile game studio making small, satisfying games." rawTitle>
  <section class="cv2-hero">
    <div class="cv2-blob cv2-blob-yellow"></div>
    <div class="cv2-blob cv2-blob-teal"></div>
    <div class="cv2-hero-inner">
      <h1>
        Small games.<br />
        <span class="accent">Big fun.</span>
      </h1>
      <div class="cv2-num-strip">
        <div class="cv2-num-item">
          <span class="n">2</span>
          <span class="l">Games</span>
        </div>
        <div class="cv2-num-sep"></div>
        <div class="cv2-num-item">
          <span class="n">1</span>
          <span class="l">Studio</span>
        </div>
        <div class="cv2-num-sep"></div>
        <div class="cv2-num-item">
          <span class="n">∞</span>
          <span class="l">Taps</span>
        </div>
      </div>
      <div class="cv2-scroll-hint" id="scrollHint">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <path d="M14 6v16M7 16l7 7 7-7" stroke="#aaa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </section>

  <GameBlock
    id="minimalist-breakout"
    variant="g1"
    title="Minimalist Breakout"
    description="A clean, distraction-free take on the timeless breakout formula. Pure gameplay, zero clutter. Built for mobile from the ground up."
    accentColor="#29C4D9"
    badgeActive={true}
    appStoreUrl="https://apps.apple.com/us/app/minimalist-breakout/id6776583255"
    icon="/icons/minimalist-breakout.png"
    screenshots={[
      '/screenshots/minimalist-breakout/1.png',
      '/screenshots/minimalist-breakout/2.png',
      '/screenshots/minimalist-breakout/3.png',
      '/screenshots/minimalist-breakout/4.png',
      '/screenshots/minimalist-breakout/5.png',
      '/screenshots/minimalist-breakout/6.png',
    ]}
  />

  <GameBlock
    id="flappy-ball"
    variant="g2"
    title="Flappy Ball Hop"
    description="Dodge, weave, and soar through an ever-changing world. Easy to learn, impossible to put down. Coming to iOS & Android."
    accentColor="#F2455C"
    badgeActive={false}
    icon="/icons/flappy-ball.png"
    screenshots={[
      '/screenshots/flappy-ball/01-menu.png',
      '/screenshots/flappy-ball/02-gameplay.png',
      '/screenshots/flappy-ball/03-combo.png',
      '/screenshots/flappy-ball/04-skins.png',
      '/screenshots/flappy-ball/05-wheel.png',
      '/screenshots/flappy-ball/06-result.png',
    ]}
  />

  <section class="studio-section reveal">
    <div class="studio-inner">
      <div class="studio-header">
        <span class="studio-eyebrow">Our Philosophy</span>
        <h2>How we build games</h2>
        <p>Small team, strong opinions. We care about the experience, not the metrics.</p>
      </div>
      <div class="studio-cards">
        <div class="studio-card reveal">
          <span class="card-num">01</span>
          <h3>No energy systems</h3>
          <p>Play as long as you want. No timers, no gates, no "come back in 4 hours." Just the game.</p>
        </div>
        <div class="studio-card reveal">
          <span class="card-num">02</span>
          <h3>Clean mechanics, polished to a shine</h3>
          <p>One great mechanic beats ten mediocre ones. We iterate until it feels right.</p>
        </div>
        <div class="studio-card reveal">
          <span class="card-num">03</span>
          <h3>Ship small. Improve fast.</h3>
          <p>We release when it's fun, not when it's feature-complete. Then we listen and keep going.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cv2-hero {
    position: relative;
    min-height: calc(100vh - var(--nav-h));
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 60px 32px;
  }

  .cv2-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: .45;
    pointer-events: none;
  }

  .cv2-blob-yellow {
    width: 420px; height: 420px;
    background: #FFC93C;
    top: -120px; left: -120px;
  }

  .cv2-blob-teal {
    width: 380px; height: 380px;
    background: #29C4D9;
    top: -80px; right: -100px;
    opacity: .35;
  }

  .cv2-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    max-width: 900px;
  }

  .cv2-hero-eyebrow {
    font-family: "Nunito", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: #888;
    border: 1px solid #eee;
    padding: 6px 16px;
    border-radius: 50px;
    background: rgba(255,255,255,.7);
  }

  .cv2-hero-inner h1 {
    font-size: clamp(52px, 9vw, 96px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #222;
  }

  .cv2-hero-inner h1 .accent { color: #F2455C; }

  .cv2-hero-sub {
    font-family: "Nunito", sans-serif;
    font-size: 16px;
    color: #666;
    line-height: 1.7;
    max-width: 520px;
  }

  .cv2-num-strip {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255,255,255,.75);
    border: 1px solid #eee;
    border-radius: 20px;
    padding: 20px 40px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    margin-top: 40px;
  }

  .cv2-num-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 0 32px;
  }

  .cv2-num-item .n {
    font-size: 40px;
    font-weight: 800;
    color: #222;
    line-height: 1;
  }

  .cv2-num-item .l {
    font-family: "Nunito", sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
    color: #888;
  }

  .cv2-num-sep {
    width: 1px;
    height: 44px;
    background: #eee;
  }

  .cv2-scroll-hint {
    margin-top: 12px;
    animation: cv2-bob 2s ease-in-out infinite;
    cursor: pointer;
  }

  @keyframes cv2-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  @media (max-width: 640px) {
    .cv2-num-strip { padding: 16px 20px; }
    .cv2-num-item { padding: 0 16px; }
    .cv2-num-item .n { font-size: 30px; }
  }

  .studio-section {
    padding: 96px clamp(32px, 6vw, 100px);
    background: var(--bg-light);
  }

  .studio-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .studio-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 56px;
  }

  .studio-eyebrow {
    display: inline-block;
    font-family: "Nunito", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 14px;
  }

  .studio-header h2 {
    font-size: clamp(30px, 4.5vw, 42px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 14px;
  }

  .studio-header p {
    font-family: "Nunito", sans-serif;
    font-size: 15.5px;
    color: var(--muted);
    line-height: 1.6;
  }

  .studio-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .studio-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px 28px;
    transition: transform .25s, box-shadow .25s;
  }

  .studio-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(0,0,0,.08);
  }

  .card-num {
    display: inline-block;
    font-size: 14px;
    font-weight: 800;
    color: var(--red);
    background: rgba(242,69,92,.1);
    padding: 5px 12px;
    border-radius: 50px;
    margin-bottom: 18px;
  }

  .studio-card h3 {
    font-size: 19px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .studio-card p {
    font-family: "Nunito", sans-serif;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
  }

  @media (max-width: 860px) {
    .studio-cards { grid-template-columns: 1fr; }
    .studio-section { padding: 72px 24px; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s ease, transform .6s ease;
  }

  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function smoothScrollTo(y: number, dur = 1100) {
    const start = window.scrollY;
    const diff = y - start;
    let t0: number | null = null;
    const ease = (t: number) =>
      t < .5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3)/2;
    const step = (ts: number) => {
      if (!t0) t0 = ts;
      const p = Math.min((ts - t0) / dur, 1);
      window.scrollTo(0, start + diff * ease(p));
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  const hint = document.getElementById('scrollHint');
  if (hint) {
    hint.addEventListener('click', () => {
      const target = document.getElementById('minimalist-breakout');
      if (target) smoothScrollTo(target.getBoundingClientRect().top + window.scrollY);
    });
  }

  const io = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.transitionDelay = `${i * 80}ms`;
        e.target.classList.add('in-view');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
