---
---

<footer class="cv2-footer">
  <div class="cv2-footer-top">
    <div class="cv2-footer-brand">
      <div class="brand-row">
        <div class="cv2-logo">M</div>
        <div class="name">MogooStudio</div>
      </div>
      <p>An independent mobile game studio making small, satisfying games.</p>
    </div>
    <div class="cv2-footer-col">
      <div class="hdr">Games</div>
      <a href="/#minimalist-breakout">Minimalist Breakout</a>
      <a href="/#flappy-ball">Flappy Ball</a>
    </div>
    <div class="cv2-footer-col">
      <div class="hdr">Studio</div>
      <a href="/about">About Us</a>
      <a href="/support">Support</a>
    </div>
  </div>
  <div class="cv2-footer-bottom">
    <span>© 2026 MogooStudio. All rights reserved.</span>
    <div class="cv2-footer-legal">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
  .cv2-footer {
    background: #181818;
    color: #eee;
    padding: 64px 28px 28px;
  }

  .cv2-footer-top {
    display: flex;
    justify-content: space-between;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto 48px;
    flex-wrap: wrap;
  }

  .cv2-footer-brand { max-width: 280px; }

  .brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .cv2-logo {
    width: 30px;
    height: 30px;
    border-radius: 9px;
    background: #F2455C;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 800;
    font-size: 15px;
    flex-shrink: 0;
  }

  .cv2-footer-brand .name {
    font-weight: 800;
    font-size: 18px;
    margin-bottom: 8px;
  }

  .cv2-footer-brand p {
    font-family: "Poppins", sans-serif;
    font-size: 13px;
    color: #999;
    line-height: 1.6;
    margin: 0;
  }

  .cv2-footer-col { min-width: 140px; }

  .cv2-footer-col .hdr {
    font-family: "Poppins", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #777;
    margin-bottom: 16px;
  }

  .cv2-footer-col a {
    display: block;
    font-family: "Poppins", sans-serif;
    font-size: 14px;
    color: #ddd;
    margin-bottom: 12px;
    transition: color .2s;
  }

  .cv2-footer-col a:hover { color: #F2455C; }

  .cv2-footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid #2c2c2c;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .cv2-footer-bottom span {
    font-family: "Poppins", sans-serif;
    font-size: 12.5px;
    color: #777;
  }

  .cv2-footer-legal { display: flex; gap: 24px; }

  .cv2-footer-legal a {
    font-family: "Poppins", sans-serif;
    font-size: 12.5px;
    color: #999;
    transition: color .2s;
  }

  .cv2-footer-legal a:hover { color: #F2455C; }
</style>
