---
import Screenshots from './Screenshots.astro';

interface Props {
  id: string;
  variant: 'g1' | 'g2';
  title: string;
  tagline?: string;
  description: string;
  accentColor: string;
  badgeActive?: boolean;
  appStoreUrl?: string;
  icon?: string;
  screenshots?: string[];
}

const {
  id,
  variant,
  title,
  tagline = '',
  description,
  accentColor,
  badgeActive = false,
  appStoreUrl = '#',
  icon = '',
  screenshots = [],
} = Astro.props;
---

<section class={`cv2-game-block ${variant}`} id={id}>
  <div class="cv2-game-section">
    <div class="cv2-game-visual" style={`background:${accentColor}22;`}>
      <div class="visual-inner" style={icon ? '' : `background:${accentColor};`}>
        {icon
          ? <img src={icon} alt={title} class="game-icon" />
          : (variant === 'g1' ? '◻' : '●')
        }
      </div>
    </div>
    <div class="cv2-game-text">
      <div class="cv2-game-tag" style={`background:${accentColor}1a; color:${accentColor};`}>
        {variant === 'g1' ? 'Puzzle' : 'Arcade'}
      </div>
      <h2>{title}</h2>
      {tagline && <p class="tagline">{tagline}</p>}
      <p class="desc">{description}</p>
      {badgeActive ? (
        <a href={appStoreUrl} target="_blank" rel="noopener" class="cv2-badge">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <span>
            <em>Download on the</em>
            App Store
          </span>
        </a>
      ) : (
        <div class="cv2-badge disabled">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <span>
            <em>Coming Soon</em>
            App Store
          </span>
        </div>
      )}
    </div>
  </div>
  <Screenshots color={accentColor} screenshots={screenshots} />
</section>

<style>
  .cv2-game-block { overflow: hidden; scroll-margin-top: var(--nav-h); }
  .cv2-game-block.g1 { background: #EFFBFC; }
  .cv2-game-block.g2 { background: #FFF1F0; }

  .cv2-game-section {
    display: flex;
    align-items: center;
    gap: 64px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 60px 20px;
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity .7s ease, transform .7s ease;
  }

  .cv2-game-block.g2 .cv2-game-section {
    flex-direction: row-reverse;
    transform: translateX(40px);
  }

  .cv2-game-section.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .cv2-game-visual {
    flex: 0 0 300px;
    height: 300px;
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .visual-inner {
    width: 160px;
    height: 160px;
    border-radius: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 56px;
    color: rgba(255,255,255,.9);
    box-shadow: 0 16px 40px rgba(0,0,0,.15);
    overflow: hidden;
  }

  .game-icon {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 36px;
  }

  .cv2-game-tag {
    display: inline-block;
    font-family: "Poppins", sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 50px;
    margin-bottom: 18px;
  }

  .cv2-game-text h2 {
    font-size: 42px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    color: #222;
  }

  .cv2-game-text .tagline {
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #555;
    margin-bottom: 14px;
  }

  .cv2-game-text .desc {
    font-family: "Poppins", sans-serif;
    font-size: 14.5px;
    color: #666;
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 420px;
  }

  .cv2-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #111;
    color: #fff;
    padding: 12px 22px;
    border-radius: 14px;
    text-decoration: none;
    transition: transform .2s, box-shadow .2s;
  }

  .cv2-badge:not(.disabled):hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,.2);
  }

  .cv2-badge.disabled { opacity: .5; cursor: default; }

  .cv2-badge span {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    font-size: 15px;
    font-weight: 700;
  }

  .cv2-badge span em {
    font-style: normal;
    font-size: 10px;
    opacity: .7;
    font-family: "Poppins", sans-serif;
  }

  .cv2-game-block.g2 :global(.cv2-shots) {
    justify-content: flex-end;
  }

  @media (max-width: 900px) {
    .cv2-game-section,
    .cv2-game-block.g2 .cv2-game-section {
      flex-direction: column;
      padding: 48px 28px 0;
      text-align: center;
      gap: 32px;
    }
    .cv2-game-visual { flex: 0 0 200px; height: 200px; }
    .cv2-game-text h2 { font-size: 32px; }
    .cv2-game-text .desc { max-width: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    },
    { rootMargin: '-45% 0px -45% 0px' }
  );
  document.querySelectorAll('.cv2-game-section').forEach((el) => obs.observe(el));
</script>
